<service>
  <id>HubAPI</id>
  <name>Hub API Server</name>
  <description>HRHub Go Backend API Server</description>
  <executable>%BASE%\hub.exe</executable>
  <workingdirectory>%BASE%</workingdirectory>
  <log mode="roll-by-size">
    <sizeThreshold>10240</sizeThreshold>
    <keepFiles>8</keepFiles>
  </log>
  <onfailure action="restart" delay="10 sec"/>
  <delayedAutoStart>true</delayedAutoStart>
  <startmode>Automatic</startmode>
  <env name="PORT" value="5000"/>
  <env name="DB_HOST" value="localhost"/>
  <env name="DB_PORT" value="5432"/>
  <env name="DB_USER" value="shakil"/>
  <env name="DB_PASS" value="123456"/>
  <env name="DB_NAME" value="hrhub"/>
  <env name="DB_SSLMODE" value="disable"/>
  <env name="JWT_SECRET" value="hrhub-secret-key-change-in-production-2024"/>
  <prestart-command>powershell -Command "if (-not (Test-Path '%BASE%\uploads')) { New-Item -ItemType Directory -Path '%BASE%\uploads' -Force }"</prestart-command>
</service>
