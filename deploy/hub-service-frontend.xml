<service>
  <id>HubWeb</id>
  <name>Hub Web Frontend</name>
  <description>HRHub Next.js Frontend Server</description>
  <executable>node</executable>
  <arguments>%BASE%\web\.next\standalone\server.js</arguments>
  <workingdirectory>%BASE%\web</workingdirectory>
  <log mode="roll-by-size">
    <sizeThreshold>10240</sizeThreshold>
    <keepFiles>8</keepFiles>
  </log>
  <onfailure action="restart" delay="10 sec"/>
  <delayedAutoStart>true</delayedAutoStart>
  <startmode>Automatic</startmode>
  <env name="PORT" value="3000"/>
  <env name="NODE_ENV" value="production"/>
  <env name="NEXT_PUBLIC_API_URL" value="http://localhost:5000/api/v1"/>
</service>
